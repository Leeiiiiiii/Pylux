# Android secrets for GitHub Actions
# Copy to credentials.env and fill in real values.

# --- Google Play upload ---
# Service account JSON key for Google Play Developer API
# Generate with:  base64 -i /path/to/play-credentials.json | tr -d '\n'
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_BASE64=

# --- Upload signing key ---
# Google Play requires AABs to be signed with an upload key.
# Google Play App Signing then re-signs with the real distribution key.
# Generate keystore base64 with:  base64 -i secrets/android/release.jks | tr -d '\n'
ANDROID_KEYSTORE_BASE64=
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=
