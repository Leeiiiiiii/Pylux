# Template: copy to secrets/macos/credentials.env (same directory; that file is not committed).
# Used by scripts/build-macos.sh and macos/build-appstore.sh.

# =============================================================================
# Standalone distribution — Developer ID DMG + notarization (scripts/build-macos.sh)
# =============================================================================
# export MACOS_SIGN_ID="Developer ID Application: Your Team (TEAMID)"
# export MACOS_CERTIFICATE_PASSWORD="..."
# export APPLE_ID="..."
# export APPLE_TEAM_ID="..."
# export APPLE_APP_SPECIFIC_PASSWORD="..."

# =============================================================================
# Mac App Store upload — local build (macos/build-appstore.sh)
# =============================================================================
# Full strings from: security find-identity -v -p codesigning
#
# export MACOS_APPSTORE_APPLICATION_SIGN_ID="Apple Distribution: Your Team (TEAMID)"
# export MACOS_APPSTORE_INSTALLER_SIGN_ID="3rd Party Mac Developer Installer: Your Team (TEAMID)"
# Path to Mac App Store .provisionprofile (Identifiers → Profiles → Mac App Store). Required for TestFlight.
# export MACOS_APPSTORE_PROVISIONING_PROFILE="$HOME/Library/MobileDevice/Provisioning Profiles/XXXXXXXX-....provisionprofile"

# =============================================================================
# GitHub Actions secrets — Mac App Store CI (.github/workflows/build-macos-appstore.yml)
# =============================================================================
# These are pasted into GitHub Secrets (Settings → Secrets → Actions).
# The App Store Connect API key secrets are shared with the iOS workflow.
#
# MACOS_APPSTORE_INSTALLER_P12_BASE64=        # base64 -i <exported-installer-cert>.p12 | pbcopy
# MACOS_APPSTORE_INSTALLER_P12_PASSWORD=      # password set when exporting the .p12
# MACOS_APPSTORE_PROVISIONING_PROFILE_BASE64= # base64 -i <mac-appstore>.provisionprofile | pbcopy
#
# Reused from iOS workflow (already in GitHub Secrets):
#   APP_STORE_CONNECT_API_KEY_KEY_ID
#   APP_STORE_CONNECT_API_KEY_ISSUER_ID
#   APP_STORE_CONNECT_API_KEY_KEY_BASE64
#   IOS_CERTIFICATE_P12_BASE64          (Apple Distribution cert — works for macOS .app signing too)
#   IOS_CERTIFICATE_PASSWORD
