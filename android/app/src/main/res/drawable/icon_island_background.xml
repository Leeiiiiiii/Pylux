<?xml version="1.0" encoding="utf-8"?>
<!-- Island background with Pylux blue border (matching iOS) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Blue glow shadow (outer) - subtle -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="23dp" />
            <solid android:color="#20009FE3" />
        </shape>
    </item>
    
    <!-- Main island with border (inset to create glow effect) -->
    <item
        android:top="1dp"
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <solid android:color="#0AFFFFFF" />
            <stroke
                android:width="1dp"
                android:color="@color/pylux_blue_border" />
        </shape>
    </item>
</layer-list>
